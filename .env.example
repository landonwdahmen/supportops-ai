POSTGRES_DB=supportopsai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=supportopsai;Username=postgres;Password=postgres
Jwt__Issuer=SupportOpsAI.Dev
Jwt__Audience=SupportOpsAI.Dev
Jwt__SigningKey=development-only-signing-key-change-before-production
Jwt__ExpiresMinutes=120

RabbitMQ__Host=localhost
RabbitMQ__Port=5672
RabbitMQ__Username=guest
RabbitMQ__Password=guest
RabbitMQ__TriageQueueName=supportops.triage.jobs

AiTriage__Provider=Mock
